from collections.abc import Coroutine
from types import TracebackType
from typing import Any, Self

__version__: str

# --- Enums ---

class SystemStatus:
    Unknown: SystemStatus
    Boot: SystemStatus
    Calibrating: SystemStatus
    Standby: SystemStatus
    Active: SystemStatus
    Critical: SystemStatus
    Emergency: SystemStatus
    Poweroff: SystemStatus

class VehicleType:
    Unknown: VehicleType
    FixedWing: VehicleType
    Quadrotor: VehicleType
    Hexarotor: VehicleType
    Octorotor: VehicleType
    Tricopter: VehicleType
    Helicopter: VehicleType
    Coaxial: VehicleType
    GroundRover: VehicleType
    Generic: VehicleType

class AutopilotType:
    Unknown: AutopilotType
    Generic: AutopilotType
    ArduPilotMega: AutopilotType
    Px4: AutopilotType

class GpsFixType:
    NoFix: GpsFixType
    Fix2d: GpsFixType
    Fix3d: GpsFixType
    Dgps: GpsFixType
    RtkFloat: GpsFixType
    RtkFixed: GpsFixType

class MavSeverity:
    Emergency: MavSeverity
    Alert: MavSeverity
    Critical: MavSeverity
    Error: MavSeverity
    Warning: MavSeverity
    Notice: MavSeverity
    Info: MavSeverity
    Debug: MavSeverity

class MissionType:
    Mission: MissionType
    Fence: MissionType
    Rally: MissionType

class MissionFrame:
    Mission: MissionFrame
    GlobalInt: MissionFrame
    GlobalRelativeAltInt: MissionFrame
    GlobalTerrainAltInt: MissionFrame
    LocalNed: MissionFrame
    Other: MissionFrame

class IssueSeverity:
    Error: IssueSeverity
    Warning: IssueSeverity

class TransferDirection:
    Upload: TransferDirection
    Download: TransferDirection

class TransferPhase:
    Idle: TransferPhase
    RequestCount: TransferPhase
    TransferItems: TransferPhase
    AwaitAck: TransferPhase
    Completed: TransferPhase
    Failed: TransferPhase
    Cancelled: TransferPhase

class ParamTransferPhase:
    Idle: ParamTransferPhase
    Downloading: ParamTransferPhase
    Writing: ParamTransferPhase
    Completed: ParamTransferPhase
    Failed: ParamTransferPhase

class ParamType:
    Uint8: ParamType
    Int8: ParamType
    Uint16: ParamType
    Int16: ParamType
    Uint32: ParamType
    Int32: ParamType
    Real32: ParamType

# --- Exception ---

class MavkitError(Exception): ...

# --- State classes ---

class VehicleState:
    @property
    def armed(self) -> bool: ...
    @property
    def custom_mode(self) -> int: ...
    @property
    def mode_name(self) -> str: ...
    @property
    def system_status(self) -> SystemStatus: ...
    @property
    def vehicle_type(self) -> VehicleType: ...
    @property
    def autopilot(self) -> AutopilotType: ...
    @property
    def system_id(self) -> int: ...
    @property
    def component_id(self) -> int: ...
    @property
    def heartbeat_received(self) -> bool: ...

class Telemetry:
    """Aggregated telemetry from all MAVLink message sources.

    Notifies on any field change. For fine-grained subscriptions, use
    per-domain types: Position, Attitude, Battery, Gps, Navigation,
    Terrain, RcChannels via the corresponding Vehicle wait methods.
    """

    @property
    def altitude_m(self) -> float | None: ...
    @property
    def speed_mps(self) -> float | None: ...
    @property
    def heading_deg(self) -> float | None: ...
    @property
    def latitude_deg(self) -> float | None: ...
    @property
    def longitude_deg(self) -> float | None: ...
    @property
    def battery_pct(self) -> float | None: ...
    @property
    def gps_fix_type(self) -> GpsFixType | None: ...
    @property
    def climb_rate_mps(self) -> float | None: ...
    @property
    def throttle_pct(self) -> float | None: ...
    @property
    def airspeed_mps(self) -> float | None: ...
    @property
    def battery_voltage_v(self) -> float | None: ...
    @property
    def battery_current_a(self) -> float | None: ...
    @property
    def gps_satellites(self) -> int | None: ...
    @property
    def gps_hdop(self) -> float | None: ...
    @property
    def roll_deg(self) -> float | None: ...
    @property
    def pitch_deg(self) -> float | None: ...
    @property
    def yaw_deg(self) -> float | None: ...
    @property
    def wp_dist_m(self) -> float | None: ...
    @property
    def nav_bearing_deg(self) -> float | None: ...
    @property
    def target_bearing_deg(self) -> float | None: ...
    @property
    def xtrack_error_m(self) -> float | None: ...
    @property
    def terrain_height_m(self) -> float | None: ...
    @property
    def height_above_terrain_m(self) -> float | None: ...
    @property
    def battery_voltage_cells(self) -> list[float] | None: ...
    @property
    def energy_consumed_wh(self) -> float | None: ...
    @property
    def battery_time_remaining_s(self) -> int | None: ...
    @property
    def rc_channels(self) -> list[int] | None: ...
    @property
    def rc_rssi(self) -> int | None: ...
    @property
    def servo_outputs(self) -> list[int] | None: ...

